# ============================================================
# GEMINI AI
# ============================================================
# Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ============================================================
# APP CONFIG
# ============================================================
APP_URL="MY_APP_URL"
NODE_ENV=production

# ============================================================
# MYSQL DATABASE (Hostinger)
# ============================================================
# Isi sesuai kredensial MySQL di Hostinger Business Panel
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_mysql_username
DB_PASS=your_mysql_password
DB_NAME=liva_agency_db

# ============================================================
# API SECURITY
# ============================================================
# Ganti dengan string random yang panjang dan aman
# Generate contoh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# ============================================================
# SMTP EMAIL
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="Liva Agency" <no-reply@liva-agency.com>
