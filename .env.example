# ============================================================
# GEMINI AI
# ============================================================
# Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ============================================================
# APP CONFIG
# ============================================================
APP_URL="MY_APP_URL"

# ============================================================
# MYSQL DATABASE (Hostinger)
# ============================================================
# Isi sesuai kredensial MySQL di Hostinger Business Panel
DB_HOST=localhost
DB_PORT=3306
DB_USER=YOUR_DATABASE_USER
DB_PASS=YOUR_DATABASE_PASSWORD
DB_NAME=YOUR_DATABASE_NAME

# ============================================================
# API SECURITY
# ============================================================
# Ganti dengan string random minimal 32 karakter
# Generate contoh: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING
ADMIN_USERNAME=CHANGE_THIS_ADMIN_USERNAME
# Gunakan ADMIN_PASSWORD plain melalui environment; akun yang dibuat aplikasi memakai scrypt.
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ALLOWED_ORIGINS=https://system.livaagency.com

# ============================================================
# SMTP EMAIL
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="Liva Agency" <no-reply@liva-agency.com>
